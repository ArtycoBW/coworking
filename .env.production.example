# PostgreSQL
POSTGRES_USER=garage_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=garage_db
DATABASE_URL=postgresql://garage_user:change_this_password@postgres:5432/garage_db

# Backend runtime
PORT=3001
FRONTEND_ORIGIN=https://example.com
RUN_DB_SEED=false

# Frontend build-time public URLs
NEXT_PUBLIC_API_URL=https://example.com
NEXT_PUBLIC_WS_URL=wss://example.com
